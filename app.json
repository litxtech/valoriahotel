{
  "expo": {
    "name": "Valoria Hotel",
    "slug": "valoria-hotel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "valoria-hotel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a365d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.valoria.hotel",
      "infoPlist": {
        "NSCameraUsageDescription": "Sözleşme onayı için QR kod okutmanız gerekiyor.",
        "NSPhotoLibraryUsageDescription": "Profil ve belge yükleme için galeri erişimi."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a365d"
      },
      "package": "com.valoria.hotel",
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-splash-screen",
        { "backgroundColor": "#1a365d" }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
